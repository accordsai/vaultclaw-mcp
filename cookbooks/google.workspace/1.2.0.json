      "entry_type": "recipe.verb.v1",
      "title": "List Gmail Labels",
      "description": "List labels for the authenticated Gmail user.",
      "tags": ["gmail", "labels", "read"],
      "connector_id": "google",
      "verb": "google.gmail.labels.list",
      "policy_version": "1",
      "request": {
        "user_id": "me"
      }
    },
    {
      "entry_id": "gmail_recipe_messages_list_inbox_v1",
      "entry_type": "recipe.verb.v1",
      "title": "List Inbox Messages",
      "description": "List inbox messages with a conservative page limit and inbox query AST.",
      "tags": ["gmail", "messages", "list", "inbox"],
      "connector_id": "google",
      "verb": "google.gmail.messages.list",
      "policy_version": "1",
      "request": {
        "user_id": "me",
        "page_limit": 25
      },
      "query_ast_v1": {
        "pred": {
          "field": "label",
          "op": "eq",
          "value": {
            "kind": "enum",
            "enum": "inbox"
          }
        }
      }
    },
    {
      "entry_id": "gmail_recipe_plan_send_status_update_v1",
      "entry_type": "recipe.plan.v1",
      "title": "Create and Send Status Update",
      "description": "Create a status draft and immediately send it.",
      "tags": ["gmail", "plan", "draft", "send", "status"],
      "plan": {
        "type": "connector.execution.plan.v1",
        "start_step_id": "create_draft",
        "steps": [
          {
            "step_id": "create_draft",
            "connector_id": "google",
            "verb": "google.gmail.drafts.create",
            "policy_version": "1",
            "request_base": {
              "user_id": "me",
              "to": ["ops@example.com"],
              "subject": "Daily Status Update",
              "text_plain": "System health is green. No incidents detected in the last 24 hours."
            }
          },
          {
            "step_id": "send_draft",
            "connector_id": "google",
            "verb": "google.gmail.drafts.send",
            "policy_version": "1",
            "request_base": {
              "user_id": "me",
              "draft_id": "draft_placeholder"
            },
            "request_bindings": [
              {
                "path": "/draft_id",
                "ref": {
                  "source": "step_output",
                  "step_id": "create_draft",
                  "path": "/draft_id"
                }
              }
            ]
          }
        ]
      }
    },
