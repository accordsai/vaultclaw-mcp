      "entry_id": "gmail_recipe_plan_send_status_update_v1",
      "entry_type": "recipe.plan.v1",
      "title": "Create and Send Status Update",
      "description": "Create a status draft and immediately send it.",
      "tags": [
        "draft",
        "gmail",
        "plan",
        "send",
        "status"
      ],
      "plan": {
        "start_step_id": "create_draft",
        "steps": [
          {
            "connector_id": "google",
            "policy_version": "1",
            "request_base": {
              "subject": "Daily Status Update",
              "text_plain": "System health is green. No incidents detected in the last 24 hours.",
              "to": [
                "ops@example.com"
              ],
              "user_id": "me"
            },
            "step_id": "create_draft",
            "verb": "google.gmail.drafts.create"
          },
          {
            "connector_id": "google",
            "policy_version": "1",
            "request_base": {
              "draft_id": "draft_placeholder",
              "user_id": "me"
            },
            "request_bindings": [
              {
                "path": "/draft_id",
                "ref": {
                  "path": "/draft_id",
                  "source": "step_output",
                  "step_id": "create_draft"
                }
              }
            ],
            "step_id": "send_draft",
            "verb": "google.gmail.drafts.send"
          }
        ],
        "type": "connector.execution.plan.v1"
      }
    },
